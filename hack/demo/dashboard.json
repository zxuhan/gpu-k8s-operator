  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Budget used",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * gwb_consumed_gpu_hours{name=\"demo\"} / (gwb_consumed_gpu_hours{name=\"demo\"} + gwb_remaining_gpu_hours{name=\"demo\"})",
          "legendFormat": "% used",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 150,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 60, "color": "yellow"},
              {"value": 100, "color": "red"}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Consumption vs quota",
      "gridPos": {"x": 8, "y": 0, "w": 10, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "gwb_consumed_gpu_hours{name=\"demo\"}", "legendFormat": "consumed"},
        {"refId": "B", "expr": "gwb_consumed_gpu_hours{name=\"demo\"} + gwb_remaining_gpu_hours{name=\"demo\"}", "legendFormat": "quota"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 3,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "consumed"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "quota"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}
            ]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pods tracked",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "gwb_tracked_pods{name=\"demo\"}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    }
